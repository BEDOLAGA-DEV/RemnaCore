# Application
APP_PORT=4000                    # HTTP server listen port
LOG_LEVEL=debug                  # Logging level: debug, info, warn, error
LOG_FORMAT=json                  # Logging format: json, console

# PostgreSQL
DATABASE_URL=postgres://platform:secret@localhost:5432/remnacore?sslmode=disable

# Valkey (Redis-compatible)
VALKEY_URL=redis://localhost:6379

# NATS
NATS_URL=nats://localhost:4222

# JWT — asymmetric RS256 key pair
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ACCESS_TOKEN_TTL=15m         # Access token time-to-live
JWT_REFRESH_TOKEN_TTL=168h       # Refresh token time-to-live (7 days)

# Remnawave VPN panel integration
REMNAWAVE_URL=http://localhost:3000
REMNAWAVE_API_TOKEN=             # <set-your-remnawave-api-token>
REMNAWAVE_WEBHOOK_SECRET=        # <set-your-remnawave-webhook-secret>

# Telegram bot
TELEGRAM_BOT_TOKEN=              # <set-your-telegram-bot-token>
